# =============================================================================
# Application
# =============================================================================
NODE_ENV=production
PORT=3000
SESSION_SECRET=<long_random_secret>

# =============================================================================
# Database
# =============================================================================
MONGO_URI=<mongodb_atlas_connection_string>

# =============================================================================
# Auth
# =============================================================================
JWT_SECRET=<long_random_secret>

# =============================================================================
# Google OAuth
# ---------------------------------------------------------------------------
# GOOGLE_CALLBACK_URL must exactly match what is registered in Google Cloud Console.
# Production  → http://<your-domain>/auth/google/callback
# Development → http://localhost:3000/auth/google/callback
# =============================================================================
GOOGLE_CLIENT_ID=<google_client_id>
GOOGLE_CLIENT_SECRET=<google_client_secret>
GOOGLE_CALLBACK_URL=http://<your-domain>/auth/google/callback
GOOGLE_REFRESH_TOKEN=<google_refresh_token>
GOOGLE_USER=<gmail_address>
GOOGLE_APP_PASSWORD=<gmail_app_password>

# =============================================================================
# AI / External APIs
# =============================================================================
GOOGLE_API_KEY=<google_api_key>
MISTRAL_API_KEY=<mistral_api_key>
TAVILY_API_KEY=<tavily_api_key>
RAPIDAPI_KEY=<rapidapi_key>
RAPIDAPI_HOST=cricbuzz-cricket.p.rapidapi.com
COINGECKO_API_KEY=<coingecko_api_key>
OPENAI_API_KEY=<openai_api_key>
GROQ_API_KEY=<groq_api_key>
